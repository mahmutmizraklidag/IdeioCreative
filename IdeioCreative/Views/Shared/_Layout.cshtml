    <link rel="icon" type="image/png" sizes="32x32" href="@Url.Content("~/img/fav/light-favicon-32x32.png")" media="(prefers-color-scheme: dark)">
    <link rel="icon" type="image/png" sizes="16x16" href="@Url.Content("~/img/fav/light-favicon-16x16.png")" media="(prefers-color-scheme: dark)">
    <link rel="apple-touch-icon" href="@Url.Content("~/img/fav/light-apple-touch-icon.png")" media="(prefers-color-scheme: dark)">

    <link rel="manifest" href="@Url.Content("~/img/fav/site.webmanifest")">

    <link rel="stylesheet" href="@Url.Content("~/assets/css/bootstrap.min.css")">

    <link rel="stylesheet" href="@Url.Content("~/assets/css/all.min.css")">

    <link rel="stylesheet" href="@Url.Content("~/assets/css/magnific-popup.css")">

    <link rel="stylesheet" href="@Url.Content("~/assets/css/nice-select.css")">

    <link rel="stylesheet" href="@Url.Content("~/assets/css/swiper.min.css")">

    <link rel="stylesheet" href="@Url.Content("~/assets/css/aos.css")">

    <link rel="stylesheet" href="@Url.Content("~/assets/css/main.css")">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flag-icons/css/flag-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
