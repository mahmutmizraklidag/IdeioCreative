    <section class="service-section pt-space pb-space">
        <div class="container position-relative">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-5 mb-xxl-17 mb-xl-12 mb-lg-10 mb-md-10 mb-sm-10 mb-9">
                <div class="pricing-title">
                    <div class="radius-btn text-uppercase cmn-border d-inline-flex radius100 py-xxl-2 py-2 px-xxl-4 px-4 theme-clr gap-xxl-4 gap-3 mb-xxl-8 mb-xl-6 mb-5">
                        Hizmetlerimiz
                        <span class="rot60 d-inline-block">
                            <i class="fas fa-arrow-up theme-clr"></i>
                        </span>
                    </div>
                    <h2 class="stitle">
                        <span style="font-weight:400 !important; font-family: 'Plus Jakarta Sans', sans-serif; font-style: normal;">Profesyonel</span> Hizmet Çözümleri
                    </h2>
                </div>
                <a asp-controller="Service" asp-action="Index"
                   class="radius-btn d-inline-flex radius100 py-xxl-2 py-2 px-xxl-5 px-5 theme-border theme-clr gap-xxl-4 gap-3 mb-xxl-8 mb-xl-6 mb-5">
                    Tüm Hizmetlerimizi Gör
                </a>
            </div>

            <!--Service Tabing section-->
            <div class="row g-xxl-6 g-4">
                <div class="service-tabing-wrap Faqs-section">
                    @foreach (var service in Model.Services)
                    {
                        var html = (service.HomeDescription ?? "")
                        .Replace("{{SERVICE_IMAGE}}", Url.Content("~/img/" + service.Image ?? "~/img/" + service.Image))
                        .Replace("{{LINK}}", Url.Action("Detail", "Service", new { slug = service.Slug }));
                        @Html.Raw(html)
                    }

                </div>
            </div>
            <!--Service Tabing section-->
        </div>
    </section>
